digraph "register_file" {
label="register_file";
rankdir="LR";
remincross=true;
n15 [ shape=octagon, label="data_out", color="black", fontcolor="black" ];
n16 [ shape=octagon, label="data_in", color="black", fontcolor="black" ];
n17 [ shape=octagon, label="address", color="black", fontcolor="black" ];
n18 [ shape=octagon, label="we", color="black", fontcolor="black" ];
n19 [ shape=octagon, label="rst", color="black", fontcolor="black" ];
n20 [ shape=octagon, label="clk", color="black", fontcolor="black" ];
v1 [ label="1'x" ];
v2 [ label="1'x" ];
c25 [ shape=record, label="{{<p21> ADDR|<p22> CLK|<p23> EN}|$12\n$memrd|{<p24> DATA}}",  ];
x0 [ shape=record, style=rounded, label="<s0> 7:0 - 7:0 ", color="black", fontcolor="black" ];
x0:e -> c25:p21:w [arrowhead=odiamond, arrowtail=odiamond, dir=both, color="black", fontcolor="black", style="setlinewidth(3)", label=""];
x4 [ shape=record, style=rounded, label="<s0> 7:0 - 7:0 ", color="black", fontcolor="black" ];
p3 [shape=box, style=rounded, label="PROC $2\n/openlane/designs/part3_regfile/src/register_file.v:15.5-24.8"];
c25:p24:e -> p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n12 [ shape=diamond, label="$1_EN" ];
p3:e -> n12:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n13 [ shape=diamond, label="$1_DATA" ];
p3:e -> n13:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n14 [ shape=diamond, label="$1_ADDR" ];
p3:e -> n14:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
p3:e -> n15:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n15:e -> p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n16:e -> p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n17:e -> x0:s0:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n17:e -> x4:s0:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n18:e -> p3:w [color="black", fontcolor="black", label=""];
n19:e -> p3:w [color="black", fontcolor="black", label=""];
n20:e -> p3:w [color="black", fontcolor="black", label=""];
v1:e -> c25:p23:w [color="black", fontcolor="black", label=""];
v2:e -> c25:p22:w [color="black", fontcolor="black", label=""];
x4:e -> p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
}
