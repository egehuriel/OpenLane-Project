digraph "full_system" {
label="full_system";
rankdir="LR";
remincross=true;
n1 [ shape=diamond, label="cpu_results", color="black", fontcolor="black" ];
n2 [ shape=diamond, label="pc_out", color="black", fontcolor="black" ];
n3 [ shape=diamond, label="cpu_result", color="black", fontcolor="black" ];
n4 [ shape=diamond, label="btn_pulse", color="black", fontcolor="black" ];
n5 [ shape=diamond, label="btn_db", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="an", color="black", fontcolor="black" ];
n7 [ shape=octagon, label="dp", color="black", fontcolor="black" ];
n8 [ shape=octagon, label="seg", color="black", fontcolor="black" ];
n9 [ shape=octagon, label="btn_step", color="black", fontcolor="black" ];
n10 [ shape=octagon, label="rst", color="black", fontcolor="black" ];
n11 [ shape=octagon, label="clk", color="black", fontcolor="black" ];
c13 [ shape=record, label="{{<p11> clk|<p10> rst|<p12> value}|u_sevenseg\nsevenseg_mux|{<p6> an|<p7> dp|<p8> seg}}",  ];
c15 [ shape=record, label="{{<p11> clk|<p10> rst}|u_cpu\ncpu_top|{<p2> pc_out|<p14> result}}",  ];
c18 [ shape=record, label="{{<p11> clk|<p10> rst|<p16> sig_in}|u_one_pulse\none_pulse|{<p17> pulse}}",  ];
c21 [ shape=record, label="{{<p19> btn_in|<p11> clk|<p10> rst}|u_debounce\ndebounce|{<p20> btn_out}}",  ];
c15:p14:e -> n1:w [color="black", fontcolor="black", label=""];
n10:e -> c13:p10:w [color="black", fontcolor="black", label=""];
n10:e -> c15:p10:w [color="black", fontcolor="black", label=""];
n10:e -> c18:p10:w [color="black", fontcolor="black", label=""];
n10:e -> c21:p10:w [color="black", fontcolor="black", label=""];
n11:e -> c13:p11:w [color="black", fontcolor="black", label=""];
n11:e -> c15:p11:w [color="black", fontcolor="black", label=""];
n11:e -> c18:p11:w [color="black", fontcolor="black", label=""];
n11:e -> c21:p11:w [color="black", fontcolor="black", label=""];
c15:p2:e -> n2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n3:e -> c13:p12:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c18:p17:e -> n4:w [color="black", fontcolor="black", label=""];
c21:p20:e -> n5:w [color="black", fontcolor="black", label=""];
n5:e -> c18:p16:w [color="black", fontcolor="black", label=""];
c13:p6:e -> n6:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c13:p7:e -> n7:w [color="black", fontcolor="black", label=""];
c13:p8:e -> n8:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n9:e -> c21:p19:w [color="black", fontcolor="black", label=""];
}
